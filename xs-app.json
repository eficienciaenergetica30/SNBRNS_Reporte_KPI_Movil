{
  "welcomeFile": "/",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "/$1",
      "destination": "backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    }
  ]
}
